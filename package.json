{
  "name": "kinetic-gmail-cleaner",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && npx esbuild server.ts --bundle --platform=node --outfile=dist/server.cjs --format=cjs --external:mongoose --external:googleapis --external:cors --external:dotenv --external:vite --external:@vitejs/plugin-react --external:@tailwindcss/vite",
    "preview": "vite preview",
    "clean": "rm -rf dist build",
    "lint": "tsc --noEmit",
    "start": "NODE_ENV=production node dist/server.cjs"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/cors": "^2.8.19",
    "@types/mongoose": "^5.11.96",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.546.0",
    "mongoose": "^8.23.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.27.4",
    "firebase-tools": "^15.12.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0"
  }
